AZURE_BACKEND_URL=https://your-backend.azurewebsites.net
DEVICE_ID=jetson-001
DEVICE_NAME=AURA Jetson
DEVICE_TYPE=jetson
DEVICE_SHARED_SECRET=put_the_same_secret_here_as_azure
DEVICE_SOFTWARE_VERSION=0.1.0

DEVICE_HEARTBEAT_SECONDS=30
DEVICE_STATUS_SECONDS=20
DEVICE_CONFIG_REFRESH_SECONDS=120
DEVICE_OFFLINE_RETRY_SECONDS=10

AURA_LLM_MODEL=llama3.2
AURA_EMBED_MODEL=nomic-embed-text
LOCAL_DB_NAME=jetson_local_db

SERIAL_PORT=/dev/ttyUSB0
INPUT_MODE=keyboard

OLLAMA_READY_DEFAULT=true
VECTOR_DB_READY_DEFAULT=true
CAMERA_READY_DEFAULT=true