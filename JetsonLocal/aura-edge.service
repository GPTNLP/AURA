[Unit]
Description=AURA Edge Local App
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USERNAME
WorkingDirectory=/home/YOUR_USERNAME/JetsonLocal
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/YOUR_USERNAME/JetsonLocal/aura_env/bin/python /home/YOUR_USERNAME/JetsonLocal/nano_main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target